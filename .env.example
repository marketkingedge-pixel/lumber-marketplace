# Copy this file to .env and fill in your own values.

# Password for the /admin area (change this).
ADMIN_PASSWORD=changeme

# Port the app runs on.
PORT=3000

# Optional: Anthropic API key to enable real AI photo scanning at /scanner.
# Get one at https://console.anthropic.com
# If left blank, the scanner still works using a built-in rule-of-thumb
# estimator instead of a real vision model.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for scanning.
ANTHROPIC_MODEL=claude-sonnet-5
