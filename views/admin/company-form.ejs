<%- include('../partials/header') %>

<h1><%= company ? 'Edit Company' : 'Add Company' %></h1>

<form class="form-card" method="post" action="/admin/companies">
  <% if (company) { %><input type="hidden" name="id" value="<%= company.id %>" /><% } %>
  <div class="form-grid">
    <div class="form-field full">
      <label for="name">Company name</label>
      <input type="text" id="name" name="name" value="<%= company ? company.name : '' %>" required />
    </div>
    <div class="form-field">
      <label for="phone">Phone</label>
      <input type="text" id="phone" name="phone" value="<%= company ? company.phone : '' %>" />
    </div>
    <div class="form-field">
      <label for="email">Email</label>
      <input type="email" id="email" name="email" value="<%= company ? company.email : '' %>" />
    </div>
    <div class="form-field full">
      <label for="location">Location</label>
      <input type="text" id="location" name="location" value="<%= company ? company.location : '' %>" />
    </div>
    <div class="form-field full">
      <label for="notes">Internal notes</label>
      <textarea id="notes" name="notes" rows="2"><%= company ? company.notes : '' %></textarea>
    </div>
  </div>
  <div style="margin-top:14px;">
    <button type="submit">Save Company</button>
    <a class="btn secondary" href="/admin">Cancel</a>
  </div>
</form>

<%- include('../partials/footer') %>
